rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Deny all client-side read/write access by default.
    // Media bytes are served through the secure backend (Admin SDK, signed URLs, or API routes),
    // which bypass these rules.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
